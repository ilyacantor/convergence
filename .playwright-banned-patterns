# Playwright banned-pattern list — single source of truth for pre-commit enforcement.
# Format: <name>|<ERE regex>
# Blank lines and lines starting with '#' are ignored.
# Hook fails commits on any match in staged *.spec.ts / *.spec.js files.
# Each pattern corresponds to an acceptance rule in CLAUDE.md § Playwright Acceptance.
#
length-greater-than-zero|\.length[[:space:]]*>[[:space:]]*0
length-greater-equal-one|\.length[[:space:]]*>=[[:space:]]*1
bare-toBeVisible|toBeVisible\([[:space:]]*\)
status-eq-200|status[[:space:]]*[=!]==?[[:space:]]*200
toContain-success|toContain\([[:space:]]*['"`]success['"`]
toBeTruthy|toBeTruthy\([[:space:]]*\)
not-toBeNull|\.not\.toBeNull\([[:space:]]*\)
toHaveCount-literal-integer|toHaveCount\([[:space:]]*[0-9]+[[:space:]]*\)
toHaveLength-empty|toHaveLength\([[:space:]]*\)
toHaveLength-literal-integer|toHaveLength\([[:space:]]*[0-9]+[[:space:]]*\)
